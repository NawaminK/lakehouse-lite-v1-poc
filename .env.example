# Copy this file to .env for local overrides.
# Do not commit real secrets.

AIRFLOW_UID=50000
DOCKER_GID=999

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_SECRET_KEY=change-this-super-secret-key-for-poc-only

TRINO_URI=trino://admin@trino:8080/iceberg/gold

# Image tags are pinned by default for reproducible POC runs.
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE_TAG=RELEASE.2025-08-13T08-35-41Z
PROMETHEUS_IMAGE_TAG=v3.5.0
GRAFANA_IMAGE_TAG=12.1.1
CADVISOR_IMAGE_TAG=v0.52.1
